# ── ToneForge backend config ────────────────────────────────────────────────
# Copy this file to backend/.env and adjust. ALL chat settings are OPTIONAL:
# tone drill, writing, STT, TTS, curriculum and progress work with NO config.
# Only the AI conversation tab (💬 Chat) needs an LLM endpoint.
#
# ── Option A: Local Ollama ($0, no API key) ──────────────────────────────
#   1) install Ollama from https://ollama.com
#   2) run:  ollama pull qwen2.5:7b
#   3) leave the values below as-is
#CHAT_BASE_URL=http://127.0.0.1:11434
#CHAT_MODEL=qwen2.5:7b

# ── Option B: 9Router + NVIDIA NIM free model ($0 forever) ───────────────
#   1) npm install -g 9router && 9router
#   2) Dashboard → Providers → connect NVIDIA NIM (free tier)
#   3) Use the config below — no API key needed, free forever
CHAT_BASE_URL=http://127.0.0.1:20128
CHAT_MODEL=nvidia/minimaxai/minimax-m2.7

# Optional bearer token. Leave EMPTY for local/9Router.
# Fill it only if you point CHAT_BASE_URL at a hosted provider with auth, e.g.:
#   CHAT_BASE_URL=https://api.openai.com
#   CHAT_MODEL=gpt-4o-mini
#   CHAT_API_KEY=sk-...
CHAT_API_KEY=
