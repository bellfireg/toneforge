# ── ToneForge backend config ────────────────────────────────────────────────
# Copy this file to backend/.env and adjust. ALL chat settings are OPTIONAL:
# tone drill, writing, STT, TTS, curriculum and progress work with NO config.
# Only the AI conversation tab (💬 Chat) needs an LLM endpoint.

# OpenAI-compatible chat endpoint (base URL, WITHOUT the trailing /v1).
# Default below = a local Ollama install ($0, no API key needed):
#   1) install Ollama from https://ollama.com
#   2) run:  ollama pull qwen2.5:7b
#   3) leave the values below as-is
CHAT_BASE_URL=http://127.0.0.1:11434
CHAT_MODEL=qwen2.5:7b

# Optional bearer token. Leave EMPTY for local Ollama.
# Fill it only if you point CHAT_BASE_URL at a hosted provider, e.g.:
#   CHAT_BASE_URL=https://api.openai.com
#   CHAT_MODEL=gpt-4o-mini
#   CHAT_API_KEY=sk-...
CHAT_API_KEY=
